---
import '@/styles/global.css';
import Header from '@/components/Header.astro';
import InstallPrompt from '@/components/InstallPrompt';

interface Props {
  title?: string;
  description?: string;
  fullBleed?: boolean;
  hideChrome?: boolean;
}

const {
  title = 'MoesMan — Tu biblioteca de manga',
  description = 'Lector y biblioteca personal de manga en español.',
  fullBleed = false,
  hideChrome = false,
} = Astro.props;
---

<!doctype html>
<html lang="es" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a0a0b" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="icon" type="image/svg+xml" href="/icon.svg" />
    <link rel="apple-touch-icon" href="/icon.svg" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <link rel="preconnect" href="https://uploads.mangadex.org" crossorigin />
    <link rel="preconnect" href="https://api.mangadex.org" crossorigin />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body class:list={[hideChrome && 'reader-mode']}>
    {!hideChrome && <Header />}
    <main class={fullBleed ? '' : 'container-app py-8 sm:py-10'}>
      <slot />
    </main>
    {!hideChrome && (
      <footer class="container-app py-10 text-xs text-fg-subtle">
        <div class="flex flex-wrap items-center justify-between gap-2 border-t border-border pt-6">
          <span>MoesMan · biblioteca personal de manga</span>
          <span>
            Datos vía <a
              href="https://mangadex.org"
              target="_blank"
              rel="noreferrer"
              class="link-hover">MangaDex</a>
          </span>
        </div>
      </footer>
    )}
    <InstallPrompt client:idle />
    <script is:inline define:vars={{ isProd: import.meta.env.PROD }}>
      if ('serviceWorker' in navigator) {
        if (isProd) {
          window.addEventListener('load', () => {
            navigator.serviceWorker.register('/sw.js').catch((err) => {
              console.warn('SW registro fallido:', err);
            });
          });
        } else {
          // En dev: desregistrar SW previo y limpiar caches (evita servir HTML viejo)
          navigator.serviceWorker.getRegistrations().then((regs) => {
            regs.forEach((r) => r.unregister());
          });
          if (window.caches) {
            caches.keys().then((keys) => keys.forEach((k) => caches.delete(k)));
          }
        }
      }
    </script>
  </body>
</html>
