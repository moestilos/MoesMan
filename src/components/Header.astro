---
import UserMenu from './UserMenu';
import Logo from './Logo.astro';

const pathname = Astro.url.pathname;
const navItem = (p: string) =>
  pathname === p || (p !== '/' && pathname.startsWith(p))
    ? 'text-fg'
    : 'text-fg-muted hover:text-fg';
const navUnderline = (p: string) =>
  pathname === p || (p !== '/' && pathname.startsWith(p)) ? 'scale-x-100' : 'scale-x-0';
const q = Astro.url.searchParams.get('q') ?? '';
---

<header
  class="sticky top-0 z-40 transition-all duration-300
         [html.scrolled_&]:bg-bg/85 [html.scrolled_&]:backdrop-blur-xl [html.scrolled_&]:shadow-[0_1px_0_0_rgba(255,255,255,0.04)]
         bg-bg/40 backdrop-blur-sm"
>
  <div class="container-app flex h-16 items-center gap-3 sm:gap-6">
    <Logo size={38} />

    <nav class="hidden md:flex items-center gap-1 text-sm font-medium ml-2">
      {[
        { href: '/', label: 'Inicio' },
        { href: '/search', label: 'Explorar' },
        { href: '/library', label: 'Biblioteca' },
      ].map(({ href, label }) => (
        <a
          href={href}
          class:list={[
            'group relative rounded-full px-3.5 py-2 transition-colors',
            navItem(href),
          ]}
        >
          <span>{label}</span>
          <span
            class:list={[
              'pointer-events-none absolute left-3.5 right-3.5 -bottom-0.5 h-0.5 rounded-full bg-brand-500 transition-transform duration-300 origin-left',
              navUnderline(href),
            ]}
          ></span>
        </a>
      ))}
    </nav>

    <form action="/search" method="get" class="flex-1 max-w-md ml-auto md:mx-auto md:max-w-[480px]">
      <label class="relative block group/search">
        <span class="sr-only">Buscar manga</span>
        <span
          class="pointer-events-none absolute inset-y-0 left-3.5 flex items-center text-fg-subtle transition-colors group-focus-within/search:text-brand-400"
          aria-hidden="true"
        >
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"></circle>
            <path d="m21 21-4.3-4.3"></path>
          </svg>
        </span>
        <input
          type="search"
          name="q"
          value={q}
          placeholder="Buscar manga, autor, género…"
          autocomplete="off"
          class="w-full rounded-full bg-bg-card/60 pl-10 pr-14 py-2.5 text-sm text-fg placeholder:text-fg-subtle
                 ring-1 ring-inset ring-border transition-all duration-200
                 focus:ring-brand-500/50 focus:bg-bg-card focus:shadow-glow-sm focus:outline-none"
        />
        <kbd
          class="pointer-events-none absolute inset-y-0 right-2.5 my-auto hidden h-6 items-center gap-1 rounded-md bg-bg-elevated px-1.5 font-mono text-2xs font-semibold text-fg-subtle ring-1 ring-border md:inline-flex"
        >
          <span>⌘</span>K
        </kbd>
      </label>
    </form>

    <div class="ml-auto md:ml-0 flex items-center gap-2">
      <a
        href="/history"
        aria-label="Historial de lectura"
        title="Historial"
        class:list={[
          'btn-icon',
          pathname === '/history' ? 'text-brand-400 ring-brand-500/50' : '',
        ]}
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M3 3v5h5"/>
          <path d="M3.05 13A9 9 0 1 0 6 5.3L3 8"/>
          <path d="M12 7v5l4 2"/>
        </svg>
      </a>
      <UserMenu client:only="react" />
    </div>
  </div>
</header>

<script is:inline>
  // Atajo ⌘K / Ctrl+K para enfocar search
  document.addEventListener('keydown', (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') {
      const input = document.querySelector('header input[name="q"]');
      if (input) {
        e.preventDefault();
        input.focus();
        input.select();
      }
    }
  });
</script>
