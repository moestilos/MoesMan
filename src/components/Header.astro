---
import UserMenu from './UserMenu';
import Logo from './Logo.astro';

const pathname = Astro.url.pathname;
const isActive = (p: string) =>
  pathname === p || (p !== '/' && pathname.startsWith(p));
const q = Astro.url.searchParams.get('q') ?? '';

const navItems = [
  { href: '/', label: 'Inicio', seccion: 'inicio' },
  { href: '/search', label: 'Explorar', seccion: 'explorar' },
  { href: '/library', label: 'Biblioteca', seccion: 'biblioteca' },
];
---

<header
  id="header-nav"
  class="fixed top-4 inset-x-0 z-50 flex justify-center px-3 sm:px-4 pointer-events-none transition-all duration-300"
>
  <div
    id="pill-nav"
    class="pointer-events-auto flex items-center gap-1 p-1.5 rounded-full border border-border-strong bg-bg-raised/80 backdrop-blur-xl shadow-2xl shadow-black/40 max-w-full transition-all duration-300 hover:border-brand-500/40"
  >
    <!-- Logo + wordmark -->
    <a
      href="/"
      aria-label="Ako — Inicio"
      class="group flex flex-none items-center gap-2 rounded-full pl-1.5 pr-3 py-0.5 hover:bg-white/[0.04] transition-colors"
    >
      <Logo size={28} withText={false} />
      <span class="hidden sm:inline font-semibold tracking-[-0.025em] text-white text-[15px] leading-none">
        Ako
      </span>
    </a>

    <span class="hidden lg:block w-px h-5 bg-border-strong mx-1"></span>

    <!-- Nav links + indicador deslizante -->
    <nav id="nav-links" class="hidden lg:flex items-center relative">
      <span
        id="nav-indicador"
        class="absolute top-1/2 -translate-y-1/2 h-8 rounded-full bg-brand-500/15 border border-brand-500/30 transition-all duration-300 ease-out opacity-0 pointer-events-none"
      ></span>
      {navItems.map((n) => (
        <a
          href={n.href}
          data-seccion={n.seccion}
          class:list={[
            'link-nav relative z-10 px-3 py-1.5 text-sm rounded-full transition-colors',
            isActive(n.href) ? 'text-white' : 'text-fg-muted hover:text-white',
          ]}
        >
          {n.label}
        </a>
      ))}
    </nav>

    <span class="hidden lg:block w-px h-5 bg-border-strong mx-1"></span>

    <!-- Search inline compacto -->
    <form action="/search" method="get" class="hidden md:block w-[200px] lg:w-[240px]">
      <label class="relative block">
        <span class="sr-only">Buscar manga</span>
        <span class="pointer-events-none absolute inset-y-0 left-3 flex items-center text-fg-subtle">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"></circle>
            <path d="m21 21-4.3-4.3"></path>
          </svg>
        </span>
        <input
          type="search"
          name="q"
          value={q}
          placeholder="Buscar…"
          autocomplete="off"
          class="h-8 w-full rounded-full bg-white/[0.04] pl-8 pr-3 text-[12.5px] text-white placeholder:text-fg-subtle ring-1 ring-inset ring-white/[0.06] outline-none transition hover:bg-white/[0.06] focus:bg-white/[0.08] focus:ring-brand-500/40"
        />
      </label>
    </form>

    <span class="hidden md:block w-px h-5 bg-border-strong mx-1"></span>

    <!-- Historial icon (md+) -->
    <a
      href="/history"
      aria-label="Historial"
      title="Historial"
      class:list={[
        'hidden md:inline-flex h-8 w-8 flex-none items-center justify-center rounded-full transition-colors',
        isActive('/history') ? 'text-brand-400 bg-brand-500/10' : 'text-fg-muted hover:text-white hover:bg-white/[0.06]',
      ]}
    >
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M3 3v5h5"/>
        <path d="M3.05 13A9 9 0 1 0 6 5.3L3 8"/>
        <path d="M12 7v5l4 2"/>
      </svg>
    </a>

    <!-- Mobile: search icon shortcut (<md hide bar) -->
    <a
      href="/search"
      aria-label="Buscar"
      class="md:hidden inline-flex h-8 w-8 items-center justify-center rounded-full text-fg-muted hover:text-white hover:bg-white/[0.06] transition-colors"
    >
      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="8"/>
        <path d="m21 21-4.3-4.3"/>
      </svg>
    </a>

    <!-- UserMenu (CTA derecha) -->
    <div class="flex-none">
      <UserMenu client:only="react" />
    </div>
  </div>
</header>

<!-- Espaciador obligatorio -->
<div class="h-20" aria-hidden="true"></div>

<script is:inline>
  (() => {
    const navLinks = document.querySelectorAll('#nav-links .link-nav');
    const indicador = document.getElementById('nav-indicador');
    const navContainer = document.getElementById('nav-links');
    if (!navLinks.length || !indicador || !navContainer) return;

    let activo = document.querySelector('#nav-links .link-nav.text-white');

    function mover(target) {
      if (!target) { indicador.style.opacity = '0'; return; }
      const cont = navContainer.getBoundingClientRect();
      const r = target.getBoundingClientRect();
      indicador.style.width = r.width + 'px';
      indicador.style.left = r.left - cont.left + 'px';
      indicador.style.opacity = '1';
    }

    navLinks.forEach((a) => a.addEventListener('mouseenter', () => mover(a)));
    navContainer.addEventListener('mouseleave', () => mover(activo));

    const init = () => requestAnimationFrame(() => mover(activo));
    init();
    window.addEventListener('load', init);
    window.addEventListener('resize', () => mover(activo));

    const header = document.getElementById('header-nav');
    let lastY = -1;
    const onScroll = () => {
      const y = window.scrollY;
      if ((y > 30) !== (lastY > 30) && header) {
        header.classList.toggle('top-2', y > 30);
        header.classList.toggle('top-4', y <= 30);
      }
      lastY = y;
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();

    document.addEventListener('keydown', (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') {
        const input = document.querySelector('header input[name="q"]');
        if (input) {
          e.preventDefault();
          input.focus();
          input.select();
        }
      }
    });
  })();
</script>
