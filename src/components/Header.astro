---
import UserMenu from './UserMenu';
import Logo from './Logo.astro';

const pathname = Astro.url.pathname;
const isActive = (p: string) =>
  pathname === p || (p !== '/' && pathname.startsWith(p));
const q = Astro.url.searchParams.get('q') ?? '';

const navItems = [
  { href: '/', label: 'Inicio' },
  { href: '/search', label: 'Explorar' },
  { href: '/library', label: 'Biblioteca' },
  { href: '/history', label: 'Historial' },
];
---

<header
  id="header-nav"
  class="header-float fixed inset-x-0 z-50 flex justify-center px-2 sm:px-4 pointer-events-none transition-all duration-300"
  style="top: calc(var(--safe-top) + 0.75rem); padding-left: max(0.5rem, var(--safe-left)); padding-right: max(0.5rem, var(--safe-right));"
>
  <div
    id="pill-nav"
    class="pointer-events-auto flex items-center gap-1.5 sm:gap-2 p-1 sm:p-1.5 rounded-full border border-white/[0.08] bg-bg-raised/85 backdrop-blur-xl shadow-[0_8px_32px_-8px_rgba(0,0,0,0.5)] max-w-full transition-all duration-300 hover:border-brand-500/40"
  >
    <!-- Logo + wordmark -->
    <a
      href="/"
      aria-label="Ako — Inicio"
      class="flex flex-none items-center gap-2 rounded-full px-2 py-1 transition-colors hover:bg-white/[0.04]"
    >
      <Logo size={28} withText={false} />
      <span class="hidden md:inline font-semibold tracking-[-0.025em] text-white text-[15px] leading-none">
        Ako
      </span>
    </a>

    <!-- Nav links con indicador deslizante (solo desktop) -->
    <nav id="nav-links" class="hidden md:flex items-center relative pl-1 pr-1 border-l border-white/[0.07]">
      <span
        id="nav-indicador"
        class="absolute top-1/2 -translate-y-1/2 h-8 rounded-full bg-white/[0.07] ring-1 ring-brand-500/30 transition-all duration-300 ease-out opacity-0 pointer-events-none"
      ></span>
      {navItems.map((n) => (
        <a
          href={n.href}
          class:list={[
            'link-nav relative z-10 px-3.5 py-1.5 text-[13.5px] font-medium rounded-full transition-colors',
            isActive(n.href) ? 'text-white' : 'text-fg-muted hover:text-white',
          ]}
        >
          {n.label}
        </a>
      ))}
    </nav>

    <!-- Search (md+) -->
    <form action="/search" method="get" class="hidden md:block ml-auto lg:ml-0 w-[180px] lg:w-[220px] border-l border-white/[0.07] pl-2">
      <label class="relative block">
        <span class="sr-only">Buscar manga</span>
        <span class="pointer-events-none absolute inset-y-0 left-3 flex items-center text-fg-subtle">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"></circle>
            <path d="m21 21-4.3-4.3"></path>
          </svg>
        </span>
        <input
          type="search"
          name="q"
          value={q}
          placeholder="Buscar…"
          autocomplete="off"
          class="h-8 w-full rounded-full bg-white/[0.04] pl-8 pr-3 text-[12.5px] text-white placeholder:text-fg-subtle ring-1 ring-inset ring-white/[0.06] outline-none transition hover:bg-white/[0.06] focus:bg-white/[0.08] focus:ring-brand-500/40"
        />
      </label>
    </form>

    <!-- Mobile: search shortcut + hint -->
    <a
      href="/search"
      aria-label="Buscar"
      class="md:hidden ml-auto inline-flex h-8 w-8 items-center justify-center rounded-full text-fg-muted hover:text-white hover:bg-white/[0.06] transition-colors"
    >
      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="8"/>
        <path d="m21 21-4.3-4.3"/>
      </svg>
    </a>

    <!-- UserMenu a la derecha -->
    <div class="flex-none border-l border-white/[0.07] pl-1">
      <UserMenu client:only="react" />
    </div>
  </div>
</header>

<div aria-hidden="true" class="header-spacer"></div>

<script is:inline>
  (() => {
    const navLinks = document.querySelectorAll('#nav-links .link-nav');
    const indicador = document.getElementById('nav-indicador');
    const navContainer = document.getElementById('nav-links');
    if (!navLinks.length || !indicador || !navContainer) return;

    const activo = document.querySelector('#nav-links .link-nav.text-white');

    function mover(target) {
      if (!target) { indicador.style.opacity = '0'; return; }
      const cont = navContainer.getBoundingClientRect();
      const r = target.getBoundingClientRect();
      indicador.style.width = r.width + 'px';
      indicador.style.left = r.left - cont.left + 'px';
      indicador.style.opacity = '1';
    }

    navLinks.forEach((a) => a.addEventListener('mouseenter', () => mover(a)));
    navContainer.addEventListener('mouseleave', () => mover(activo));

    const init = () => requestAnimationFrame(() => mover(activo));
    init();
    window.addEventListener('load', init);
    window.addEventListener('resize', init);

    const header = document.getElementById('header-nav');
    let lastY = -1;
    const onScroll = () => {
      const y = window.scrollY;
      if ((y > 30) !== (lastY > 30) && header) {
        header.classList.toggle('scrolled', y > 30);
      }
      lastY = y;
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();

    document.addEventListener('keydown', (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') {
        const input = document.querySelector('header input[name="q"]');
        if (input) {
          e.preventDefault();
          input.focus();
          input.select();
        }
      }
    });
  })();
</script>
