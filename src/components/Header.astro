---
import UserMenu from './UserMenu';
import Logo from './Logo.astro';

const pathname = Astro.url.pathname;
const isActive = (p: string) =>
  pathname === p
    ? 'text-fg after:scale-x-100'
    : 'text-fg-muted hover:text-fg after:scale-x-0 hover:after:scale-x-100';
const q = Astro.url.searchParams.get('q') ?? '';
---

<header class="sticky top-0 z-40 border-b border-border/60 bg-bg/70 backdrop-blur-xl supports-[backdrop-filter]:bg-bg/60">
  <div class="container-app flex h-16 items-center gap-3 sm:gap-6">
    <Logo size={36} />

    <nav class="hidden md:flex items-center gap-6 text-sm font-medium">
      <a href="/" class:list={['relative py-1 transition-colors after:absolute after:-bottom-0.5 after:left-0 after:h-0.5 after:w-full after:origin-left after:bg-brand-500 after:transition-transform after:duration-300', isActive('/')]}>Inicio</a>
      <a href="/search" class:list={['relative py-1 transition-colors after:absolute after:-bottom-0.5 after:left-0 after:h-0.5 after:w-full after:origin-left after:bg-brand-500 after:transition-transform after:duration-300', isActive('/search')]}>Explorar</a>
      <a href="/library" class:list={['relative py-1 transition-colors after:absolute after:-bottom-0.5 after:left-0 after:h-0.5 after:w-full after:origin-left after:bg-brand-500 after:transition-transform after:duration-300', isActive('/library')]}>Biblioteca</a>
    </nav>

    <form action="/search" method="get" class="flex-1 max-w-md ml-auto md:mx-auto md:max-w-sm lg:max-w-md">
      <label class="relative block group/search">
        <span class="sr-only">Buscar manga</span>
        <span
          class="pointer-events-none absolute inset-y-0 left-3.5 flex items-center text-fg-subtle transition-colors group-focus-within/search:text-brand-400"
          aria-hidden="true"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"></circle>
            <path d="m21 21-4.3-4.3"></path>
          </svg>
        </span>
        <input
          type="search"
          name="q"
          value={q}
          placeholder="Buscar manga…"
          autocomplete="off"
          class="w-full rounded-full bg-bg-card/80 pl-10 pr-4 py-2.5 text-sm text-fg placeholder:text-fg-subtle ring-1 ring-inset ring-border focus:ring-brand-500/60 focus:bg-bg-card focus:outline-none transition-all duration-200"
        />
        <span class="pointer-events-none absolute inset-y-0 right-3 hidden items-center md:flex">
          <kbd class="rounded border border-border bg-bg-elevated px-1.5 py-0.5 text-[10px] font-mono text-fg-subtle opacity-0 transition-opacity group-focus-within/search:opacity-0">⏎</kbd>
        </span>
      </label>
    </form>

    <div class="ml-auto md:ml-0 flex items-center gap-2">
      <a
        href="/history"
        aria-label="Historial de lectura"
        title="Historial"
        class={`inline-flex h-9 w-9 items-center justify-center rounded-full bg-bg-card ring-1 ring-border transition hover:ring-brand-500/40 ${pathname === '/history' ? 'text-brand-400 ring-brand-500/50' : 'text-fg-muted hover:text-fg'}`}
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M3 3v5h5"/>
          <path d="M3.05 13A9 9 0 1 0 6 5.3L3 8"/>
          <path d="M12 7v5l4 2"/>
        </svg>
      </a>
      <UserMenu client:only="react" />
    </div>
  </div>
</header>
