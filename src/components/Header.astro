---
import UserMenu from './UserMenu';
import Logo from './Logo.astro';

const pathname = Astro.url.pathname;
const isActive = (p: string) =>
  pathname === p || (p !== '/' && pathname.startsWith(p));
const q = Astro.url.searchParams.get('q') ?? '';

const navItems = [
  { href: '/', label: 'Inicio' },
  { href: '/search', label: 'Explorar' },
  { href: '/library', label: 'Biblioteca' },
];
---

<header
  class="fixed inset-x-0 top-0 z-40 flex justify-center pointer-events-none
         px-3 pt-3 sm:px-4 sm:pt-4"
>
  <div
    class="pointer-events-auto flex h-12 w-full max-w-[1120px] items-center gap-1.5 rounded-full
           bg-bg-card/70 pl-1.5 pr-1.5 ring-1 ring-border-strong
           shadow-[0_4px_24px_-6px_rgba(0,0,0,0.6),0_1px_0_0_rgba(255,255,255,0.04)_inset]
           backdrop-blur-2xl backdrop-saturate-150
           transition-shadow duration-300
           [html.scrolled_&]:shadow-[0_10px_32px_-8px_rgba(0,0,0,0.75),0_1px_0_0_rgba(255,255,255,0.06)_inset]"
  >
    <a
      href="/"
      aria-label="MoesMan — Inicio"
      class="group flex h-9 flex-none items-center gap-2 rounded-full pl-1.5 pr-3 hover:bg-bg-hover/50 transition-colors"
    >
      <span class="flex-none">
        <Logo size={28} withText={false} />
      </span>
      <span class="hidden sm:inline font-display text-sm font-extrabold tracking-tight">
        Moes<span class="text-gradient-brand">Man</span>
      </span>
    </a>

    <span class="hidden sm:inline-block h-5 w-px bg-border-strong"></span>

    <nav class="hidden md:flex items-center gap-0.5">
      {navItems.map((n) => {
        const active = isActive(n.href);
        return (
          <a
            href={n.href}
            class:list={[
              'inline-flex h-9 items-center rounded-full px-3.5 text-[13px] font-semibold tracking-tight transition-all',
              active
                ? 'bg-gradient-brand text-white shadow-glow-sm'
                : 'text-fg-muted hover:text-fg hover:bg-bg-hover/60',
            ]}
          >
            {n.label}
          </a>
        );
      })}
    </nav>

    <span class="hidden md:inline-block h-5 w-px bg-border-strong mx-0.5"></span>

    <form action="/search" method="get" class="flex-1 min-w-0 max-w-[360px] ml-auto md:ml-0">
      <label class="relative block group/search">
        <span class="sr-only">Buscar manga</span>
        <span
          class="pointer-events-none absolute inset-y-0 left-3 flex items-center text-fg-subtle transition-colors group-focus-within/search:text-brand-400"
          aria-hidden="true"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"></circle>
            <path d="m21 21-4.3-4.3"></path>
          </svg>
        </span>
        <input
          type="search"
          name="q"
          value={q}
          placeholder="Buscar…"
          autocomplete="off"
          class="h-9 w-full rounded-full bg-bg-elevated/70 pl-8 pr-10 text-[13px] text-fg placeholder:text-fg-subtle
                 ring-1 ring-inset ring-border/80 transition-all duration-200
                 focus:ring-brand-500/50 focus:bg-bg-elevated focus:shadow-glow-sm focus:outline-none"
        />
        <kbd
          class="pointer-events-none absolute right-2 top-1/2 -translate-y-1/2 hidden h-5 items-center gap-0.5 rounded bg-bg/70 px-1.5 font-mono text-[10px] font-semibold text-fg-subtle ring-1 ring-border md:inline-flex"
        >
          <span>⌘</span>K
        </kbd>
      </label>
    </form>

    <span class="inline-block h-5 w-px bg-border-strong"></span>

    <a
      href="/history"
      aria-label="Historial"
      title="Historial"
      class:list={[
        'inline-flex h-9 w-9 flex-none items-center justify-center rounded-full transition-colors',
        isActive('/history') ? 'text-brand-400 bg-brand-500/10' : 'text-fg-muted hover:text-fg hover:bg-bg-hover/60',
      ]}
    >
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M3 3v5h5"/>
        <path d="M3.05 13A9 9 0 1 0 6 5.3L3 8"/>
        <path d="M12 7v5l4 2"/>
      </svg>
    </a>

    <UserMenu client:only="react" />
  </div>
</header>

<div aria-hidden="true" class="h-[72px] sm:h-[80px]"></div>

<script is:inline>
  document.addEventListener('keydown', (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') {
      const input = document.querySelector('header input[name="q"]');
      if (input) {
        e.preventDefault();
        input.focus();
        input.select();
      }
    }
  });
</script>
