---
interface Props {
  size?: number;
  withText?: boolean;
  className?: string;
}
const { size = 36, withText = true, className = '' } = Astro.props;
const uid = Math.random().toString(36).slice(2, 8);
---

<a href="/" class:list={['group flex items-center gap-2.5 select-none', className]} aria-label="MoesMan — Inicio">
  <svg
    width={size}
    height={size}
    viewBox="0 0 64 64"
    xmlns="http://www.w3.org/2000/svg"
    aria-hidden="true"
    class="transition-transform duration-300 group-hover:scale-105"
  >
    <defs>
      <linearGradient id={`lg-bg-${uid}`} x1="0" y1="0" x2="1" y2="1">
        <stop offset="0%" stop-color="#1a1a1f"/>
        <stop offset="100%" stop-color="#0a0a0b"/>
      </linearGradient>
      <linearGradient id={`lg-brand-${uid}`} x1="0" y1="0" x2="1" y2="1">
        <stop offset="0%" stop-color="#fb7185"/>
        <stop offset="60%" stop-color="#f43f5e"/>
        <stop offset="100%" stop-color="#be123c"/>
      </linearGradient>
      <linearGradient id={`lg-acc-${uid}`} x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="#c4b5fd"/>
        <stop offset="100%" stop-color="#7c3aed"/>
      </linearGradient>
    </defs>
    <rect width="64" height="64" rx="14" fill={`url(#lg-bg-${uid})`}/>
    <g>
      <path
        d="M 14 48 L 14 20 Q 14 16 18 16 L 22 16 Q 25 16 27 19 L 32 35 L 29 44 Z"
        fill={`url(#lg-brand-${uid})`}
      />
      <path
        d="M 50 48 L 50 20 Q 50 16 46 16 L 42 16 Q 39 16 37 19 L 32 35 L 35 44 Z"
        fill={`url(#lg-brand-${uid})`}
      />
      <path d="M 29 44 L 32 35 L 35 44 Z" fill={`url(#lg-acc-${uid})`} opacity="0.95"/>
      <circle cx="32" cy="52" r="2" fill={`url(#lg-brand-${uid})`}/>
    </g>
    <path d="M 52 10 L 58 10 L 58 16" fill="none" stroke={`url(#lg-brand-${uid})`} stroke-width="1.5" stroke-linecap="round"/>
    <path d="M 6 54 L 6 48 M 6 54 L 12 54" fill="none" stroke={`url(#lg-acc-${uid})`} stroke-width="1.5" stroke-linecap="round" opacity="0.75"/>
  </svg>
  {withText && (
    <span class="flex flex-col leading-none">
      <span class="text-[17px] font-extrabold tracking-tight text-fg group-hover:text-brand-300 transition-colors">
        Moes<span class="text-brand-400">Man</span>
      </span>
      <span class="mt-0.5 text-[9px] font-semibold uppercase tracking-[0.18em] text-fg-subtle">
        Manga Library
      </span>
    </span>
  )}
</a>
