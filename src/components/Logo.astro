---
interface Props {
  size?: number;
  withText?: boolean;
  className?: string;
}
const { size = 32, withText = true, className = '' } = Astro.props;
const uid = Math.random().toString(36).slice(2, 8);
---

<a href="/" class:list={['group inline-flex items-center gap-2.5 select-none', className]} aria-label="MoesMan">
  <span class="relative flex-none" style={`width:${size}px;height:${size}px`}>
    <svg
      viewBox="0 0 40 40"
      xmlns="http://www.w3.org/2000/svg"
      aria-hidden="true"
      class="h-full w-full transition-transform duration-500 ease-out group-hover:rotate-[8deg]"
    >
      <defs>
        <linearGradient id={`lg-${uid}`} x1="0" y1="0" x2="1" y2="1">
          <stop offset="0%" stop-color="rgb(var(--brand-400))"/>
          <stop offset="100%" stop-color="rgb(var(--brand-700))"/>
        </linearGradient>
      </defs>
      <!-- Torii-inspired: two columns + top beam (Japanese zen) -->
      <rect width="40" height="40" rx="10" fill="rgb(var(--brand-950) / 0.85)"/>
      <rect x="0.5" y="0.5" width="39" height="39" rx="9.5" fill="none" stroke="rgba(255,255,255,0.08)"/>
      <!-- Top beam -->
      <rect x="7" y="10" width="26" height="3" rx="1" fill={`url(#lg-${uid})`}/>
      <!-- Second beam slightly thinner -->
      <rect x="9" y="15" width="22" height="2" rx="0.8" fill={`url(#lg-${uid})`} opacity="0.8"/>
      <!-- Left column -->
      <rect x="12" y="13" width="3" height="17" rx="1" fill={`url(#lg-${uid})`}/>
      <!-- Right column -->
      <rect x="25" y="13" width="3" height="17" rx="1" fill={`url(#lg-${uid})`}/>
      <!-- Bottom dot -->
      <circle cx="20" cy="30" r="1.5" fill={`url(#lg-${uid})`}/>
    </svg>
  </span>
  {withText && (
    <span class="font-display text-[15px] font-extrabold tracking-tight leading-none">
      Moes<span class="text-gradient-brand">Man</span>
    </span>
  )}
</a>
