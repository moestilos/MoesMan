---
interface Props {
  count?: number;
}
const { count = 12 } = Astro.props;
const arr = Array.from({ length: count });
---

<div class="grid gap-3 sm:gap-4 lg:gap-5 grid-cols-2 xs:grid-cols-3 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 2xl:grid-cols-7">
  {arr.map((_, i) => (
    <div
      class="relative animate-fade-in"
      style={`animation-delay: ${Math.min(i * 35, 350)}ms`}
    >
      <div class="skeleton aspect-[2/3] rounded-xl ring-1 ring-border/60">
        <div class="absolute inset-x-3 bottom-3 space-y-1.5">
          <div class="h-3 w-4/5 rounded bg-white/[0.05]"></div>
          <div class="h-2.5 w-2/5 rounded bg-white/[0.04]"></div>
        </div>
      </div>
    </div>
  ))}
</div>
