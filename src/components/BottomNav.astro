---
const pathname = Astro.url.pathname;
const isActive = (p: string) =>
  pathname === p || (p !== '/' && pathname.startsWith(p));

const items = [
  {
    href: '/',
    label: 'Inicio',
    icon: '<path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2h-4V12h-6v10H5a2 2 0 0 1-2-2z"/>',
  },
  {
    href: '/search',
    label: 'Explorar',
    icon: '<circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/>',
  },
  {
    href: '/library',
    label: 'Biblioteca',
    icon: '<path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>',
  },
  {
    href: '/friends',
    label: 'Amigos',
    icon: '<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>',
  },
  {
    href: '/history',
    label: 'Historial',
    icon: '<path d="M3 3v5h5"/><path d="M3.05 13A9 9 0 1 0 6 5.3L3 8"/><path d="M12 7v5l4 2"/>',
  },
];
---

<nav
  aria-label="Navegación móvil"
  class="fixed bottom-0 left-0 right-0 z-40 border-t border-border bg-bg/85 backdrop-blur-xl md:hidden"
  style="padding-bottom: var(--safe-bottom); padding-left: var(--safe-left); padding-right: var(--safe-right);"
>
  <ul class="grid grid-cols-5">
    {items.map((it) => {
      const active = isActive(it.href);
      return (
        <li>
          <a
            href={it.href}
            class:list={[
              'group flex flex-col items-center justify-center gap-1 py-2.5 transition-colors',
              active ? 'text-brand-400' : 'text-fg-subtle hover:text-fg',
            ]}
          >
            <span
              class:list={[
                'relative flex h-8 w-11 xs:h-9 xs:w-12 items-center justify-center rounded-xl transition-all',
                active ? 'bg-brand-500/15' : 'group-hover:bg-bg-card',
              ]}
            >
              <svg
                width="17"
                height="17"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                set:html={it.icon}
              />
            </span>
            <span class="text-[10px] font-semibold tracking-wide">{it.label}</span>
          </a>
        </li>
      );
    })}
  </ul>
</nav>
<div class="md:hidden" aria-hidden="true" style="height: calc(var(--bottomnav-h) + var(--safe-bottom));"></div>
