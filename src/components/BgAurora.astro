---
// Fondo animado "aurora" — 4 blobs GPU-accelerated, bajo z-index, perf-friendly.
// Respeta prefers-reduced-motion.
---

<div aria-hidden="true" class="aurora">
  <div class="aurora-blob aurora-blob--1"></div>
  <div class="aurora-blob aurora-blob--2"></div>
  <div class="aurora-blob aurora-blob--3"></div>
  <div class="aurora-blob aurora-blob--4"></div>
  <div class="aurora-grain"></div>
</div>

<style>
  .aurora {
    position: fixed;
    inset: 0;
    z-index: 0;
    overflow: hidden;
    pointer-events: none;
    background: #08080b;
    isolation: isolate;
  }
  .aurora-blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(90px);
    mix-blend-mode: screen;
    opacity: 0.55;
    will-change: transform;
    transform: translate3d(0, 0, 0);
  }
  .aurora-blob--1 {
    width: 55vw;
    height: 55vw;
    min-width: 520px;
    min-height: 520px;
    top: -15vh;
    left: -10vw;
    background: radial-gradient(circle at 30% 30%, #f5356a 0%, transparent 70%);
    animation: drift1 42s ease-in-out infinite;
  }
  .aurora-blob--2 {
    width: 60vw;
    height: 60vw;
    min-width: 620px;
    min-height: 620px;
    top: 10vh;
    right: -20vw;
    background: radial-gradient(circle at 50% 50%, #8b5cf6 0%, transparent 70%);
    animation: drift2 58s ease-in-out infinite;
    opacity: 0.42;
  }
  .aurora-blob--3 {
    width: 50vw;
    height: 50vw;
    min-width: 460px;
    min-height: 460px;
    bottom: -20vh;
    left: 20vw;
    background: radial-gradient(circle at 50% 50%, #ff6a8e 0%, transparent 65%);
    animation: drift3 66s ease-in-out infinite;
    opacity: 0.35;
  }
  .aurora-blob--4 {
    width: 40vw;
    height: 40vw;
    min-width: 360px;
    min-height: 360px;
    top: 45vh;
    left: 30vw;
    background: radial-gradient(circle at 50% 50%, #7c3aed 0%, transparent 70%);
    animation: drift4 50s ease-in-out infinite;
    opacity: 0.22;
  }
  .aurora-grain {
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='3'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-size: 256px 256px;
    opacity: 0.03;
    mix-blend-mode: overlay;
    pointer-events: none;
  }
  /* Capa oscura encima para mantener contraste de texto */
  .aurora::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 50% 0%, transparent 0%, rgba(8, 8, 11, 0.55) 60%, rgba(8, 8, 11, 0.85) 100%),
      linear-gradient(to bottom, rgba(8, 8, 11, 0.3) 0%, rgba(8, 8, 11, 0.65) 100%);
    pointer-events: none;
  }

  @keyframes drift1 {
    0%, 100% { transform: translate3d(0, 0, 0) scale(1); }
    33% { transform: translate3d(6vw, 4vh, 0) scale(1.15); }
    66% { transform: translate3d(-3vw, 6vh, 0) scale(0.95); }
  }
  @keyframes drift2 {
    0%, 100% { transform: translate3d(0, 0, 0) scale(1); }
    50% { transform: translate3d(-10vw, 8vh, 0) scale(1.2); }
  }
  @keyframes drift3 {
    0%, 100% { transform: translate3d(0, 0, 0) scale(1); }
    40% { transform: translate3d(8vw, -6vh, 0) scale(0.9); }
    70% { transform: translate3d(-6vw, -3vh, 0) scale(1.1); }
  }
  @keyframes drift4 {
    0%, 100% { transform: translate3d(0, 0, 0) scale(1); }
    50% { transform: translate3d(5vw, -10vh, 0) scale(1.3); }
  }

  @media (prefers-reduced-motion: reduce) {
    .aurora-blob {
      animation: none !important;
    }
  }
</style>
