---
import type { MangaSummary } from '@/lib/providers/types';

interface Props {
  manga: MangaSummary;
  priority?: boolean;
  size?: 'sm' | 'md' | 'lg';
  rank?: number;
}
const { manga, priority = false, size = 'md', rank } = Astro.props;
const href = `/manga/${manga.id}`;
const cover = manga.coverUrl ?? '/placeholder-cover.svg';
const statusLabel: Record<string, { label: string; tone: string; dot: string }> = {
  ongoing: { label: 'En curso', tone: 'text-emerald-300 ring-emerald-500/25 bg-emerald-500/10', dot: 'bg-emerald-400' },
  completed: { label: 'Completo', tone: 'text-sky-300 ring-sky-500/25 bg-sky-500/10', dot: 'bg-sky-400' },
  hiatus: { label: 'Pausado', tone: 'text-amber-300 ring-amber-500/25 bg-amber-500/10', dot: 'bg-amber-400' },
  cancelled: { label: 'Cancelado', tone: 'text-rose-300 ring-rose-500/25 bg-rose-500/10', dot: 'bg-rose-400' },
  unknown: { label: '', tone: '', dot: '' },
};
const statusInfo = manga.status ? statusLabel[manga.status] : statusLabel.unknown;
const isNsfw = manga.contentRating === 'pornographic';
const isEcchi = manga.contentRating === 'erotica';
---

<a
  href={href}
  class="group relative block rounded-xl outline-none focus-visible:ring-2 focus-visible:ring-brand-500/60 focus-visible:ring-offset-2 focus-visible:ring-offset-bg"
>
  <div class="relative aspect-[2/3] w-full overflow-hidden rounded-xl bg-bg-card ring-1 ring-border transition-all duration-300 ease-out group-hover:ring-brand-500/30 group-hover:shadow-card-lg">
    <img
      src={cover}
      alt={manga.title}
      loading={priority ? 'eager' : 'lazy'}
      decoding="async"
      class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 ease-out group-hover:scale-[1.03]"
      onerror="this.src='/placeholder-cover.svg'"
    />

    <!-- Base vignette -->
    <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-black/90 via-black/20 to-transparent"></div>

    <!-- Subtle brand tint on hover -->
    <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-brand-950/0 via-transparent to-transparent opacity-0 transition-opacity duration-500 group-hover:from-brand-900/50 group-hover:opacity-100"></div>

    <!-- Inner highlight for glass feel -->
    <div class="pointer-events-none absolute inset-0 rounded-xl shadow-[inset_0_1px_0_0_rgba(255,255,255,0.05)]"></div>

    <!-- Rank badge top-left -->
    {rank !== undefined && (
      <div class="absolute left-2 top-2">
        <span class="inline-flex h-6 min-w-6 items-center justify-center rounded-md bg-black/75 px-1.5 font-mono text-[11px] font-bold text-white ring-1 ring-white/10 backdrop-blur-sm">
          #{rank}
        </span>
      </div>
    )}

    <!-- Right-top badges -->
    <div class="absolute right-2 top-2 flex flex-col items-end gap-1">
      {isNsfw && (
        <span class="inline-flex items-center rounded bg-rose-600/90 px-1.5 py-0.5 text-[9px] font-bold uppercase tracking-wider text-white ring-1 ring-rose-400/30">
          18+
        </span>
      )}
      {isEcchi && !isNsfw && (
        <span class="inline-flex items-center rounded bg-rose-500/75 px-1.5 py-0.5 text-[9px] font-bold uppercase tracking-wider text-white ring-1 ring-rose-400/30">
          16+
        </span>
      )}
      {statusInfo.label && (
        <span class:list={['inline-flex items-center gap-1 rounded px-1.5 py-0.5 text-[9px] font-semibold ring-1 ring-inset backdrop-blur-sm', statusInfo.tone]}>
          <span class:list={['inline-block h-1 w-1 rounded-full', statusInfo.dot]}></span>
          {statusInfo.label}
        </span>
      )}
    </div>

    <!-- Title + meta at bottom -->
    <div class="absolute inset-x-0 bottom-0 p-3">
      <h3
        class="line-clamp-2 text-[13px] font-semibold leading-snug text-white drop-shadow-[0_1px_3px_rgba(0,0,0,0.9)]"
        title={manga.title}
      >
        {manga.title}
      </h3>
      <div class="mt-1 flex items-center gap-1.5 text-[10px] font-medium text-white/65">
        {manga.year && <span class="tabular-nums">{manga.year}</span>}
        {manga.year && manga.tags && manga.tags.length > 0 && <span class="opacity-40">·</span>}
        {manga.tags && manga.tags.length > 0 && (
          <span class="line-clamp-1">{manga.tags.slice(0, 2).join(' · ')}</span>
        )}
      </div>
    </div>
  </div>
</a>
