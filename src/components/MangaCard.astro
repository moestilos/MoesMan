---
import type { MangaSummary } from '@/lib/providers/types';

interface Props {
  manga: MangaSummary;
  priority?: boolean;
  size?: 'sm' | 'md' | 'lg';
  rank?: number;
}
const { manga, priority = false, size = 'md', rank } = Astro.props;
const href = `/manga/${manga.id}`;
const cover = manga.coverUrl ?? '/placeholder-cover.svg';
const statusLabel: Record<string, { label: string; dot: string }> = {
  ongoing: { label: 'En curso', dot: 'bg-emerald-400 shadow-[0_0_6px_rgba(52,211,153,0.7)]' },
  completed: { label: 'Completo', dot: 'bg-sky-400 shadow-[0_0_6px_rgba(56,189,248,0.7)]' },
  hiatus: { label: 'Pausado', dot: 'bg-amber-400 shadow-[0_0_6px_rgba(251,191,36,0.7)]' },
  cancelled: { label: 'Cancelado', dot: 'bg-rose-400 shadow-[0_0_6px_rgba(248,113,113,0.7)]' },
  unknown: { label: '', dot: '' },
};
const statusInfo = manga.status ? statusLabel[manga.status] : statusLabel.unknown;
const isNsfw = manga.contentRating === 'pornographic';
const isEcchi = manga.contentRating === 'erotica';
---

<a
  href={href}
  class="group relative block rounded-xl outline-none focus-visible:ring-2 focus-visible:ring-brand-500/60 focus-visible:ring-offset-2 focus-visible:ring-offset-bg"
>
  <div class="relative aspect-[2/3] w-full overflow-hidden rounded-xl bg-bg-card ring-1 ring-border transition-[box-shadow,transform] duration-[var(--dur-base)] ease-[var(--ease-out)] group-hover:ring-brand-500/35 group-hover:shadow-card-lg group-active:scale-[0.985]">
    <img
      src={cover}
      alt={manga.title}
      loading={priority ? 'eager' : 'lazy'}
      decoding="async"
      class="absolute inset-0 h-full w-full object-cover transition-transform duration-[650ms] ease-[var(--ease-out)] group-hover:scale-[1.04]"
      onerror="this.src='/placeholder-cover.svg'"
    />

    <!-- Base vignette -->
    <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-black/90 via-black/20 to-transparent"></div>

    <!-- Subtle brand tint on hover -->
    <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-brand-950/0 via-transparent to-transparent opacity-0 transition-opacity duration-500 group-hover:from-brand-900/50 group-hover:opacity-100"></div>

    <!-- Inner highlight for glass feel -->
    <div class="pointer-events-none absolute inset-0 rounded-xl shadow-[inset_0_1px_0_0_rgba(255,255,255,0.05)]"></div>

    <!-- Rank badge top-left -->
    {rank !== undefined && (
      <div class="absolute left-2 top-2">
        <span class="inline-flex h-7 min-w-7 items-center justify-center rounded-lg bg-black/80 px-2 font-mono text-[11px] font-bold tabular-nums text-white ring-1 ring-white/10 backdrop-blur-sm">
          #{rank}
        </span>
      </div>
    )}

    <!-- Rating badge top-right (18+/16+ only, high priority warning) -->
    {(isNsfw || isEcchi) && (
      <div class="absolute right-2 top-2">
        <span class:list={[
          'inline-flex items-center rounded-md px-1.5 py-0.5 text-[10px] font-black tracking-wider text-white ring-1 backdrop-blur-sm',
          isNsfw
            ? 'bg-rose-600/95 ring-rose-400/40 shadow-[0_0_10px_-2px_rgba(244,63,94,0.6)]'
            : 'bg-rose-500/70 ring-rose-400/30',
        ]}>
          {isNsfw ? '18+' : '16+'}
        </span>
      </div>
    )}

    <!-- Title + status + meta at bottom -->
    <div class="absolute inset-x-0 bottom-0 p-3">
      {statusInfo.label && (
        <div class="mb-1.5 inline-flex items-center gap-1.5 text-[10px] font-semibold uppercase tracking-wider text-white/90">
          <span class:list={['inline-block h-1.5 w-1.5 flex-none rounded-full', statusInfo.dot]}></span>
          <span>{statusInfo.label}</span>
        </div>
      )}
      <h3
        class="line-clamp-2 text-[13px] font-semibold leading-snug text-white drop-shadow-[0_1px_3px_rgba(0,0,0,0.9)]"
        title={manga.title}
      >
        {manga.title}
      </h3>
      <div class="mt-1 flex items-center gap-1.5 text-[10px] font-medium text-white/65">
        {manga.year && <span class="tabular-nums">{manga.year}</span>}
        {manga.year && manga.tags && manga.tags.length > 0 && <span class="opacity-40">·</span>}
        {manga.tags && manga.tags.length > 0 && (
          <span class="line-clamp-1">{manga.tags.slice(0, 2).join(' · ')}</span>
        )}
      </div>
    </div>
  </div>
</a>
