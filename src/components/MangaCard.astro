---
import type { MangaSummary } from '@/lib/providers/types';

interface Props {
  manga: MangaSummary;
  priority?: boolean;
}
const { manga, priority = false } = Astro.props;
const href = `/manga/${manga.id}`;
const cover = manga.coverUrl ?? '/placeholder-cover.svg';
const statusLabel: Record<string, { label: string; tone: string }> = {
  ongoing: { label: 'En curso', tone: 'bg-emerald-500/15 text-emerald-300 ring-emerald-500/30' },
  completed: { label: 'Completo', tone: 'bg-sky-500/15 text-sky-300 ring-sky-500/30' },
  hiatus: { label: 'Pausado', tone: 'bg-amber-500/15 text-amber-300 ring-amber-500/30' },
  cancelled: { label: 'Cancelado', tone: 'bg-rose-500/15 text-rose-300 ring-rose-500/30' },
  unknown: { label: '', tone: '' },
};
const statusInfo = manga.status ? statusLabel[manga.status] : statusLabel.unknown;
const isNsfw = manga.contentRating === 'erotica' || manga.contentRating === 'pornographic';
---

<a
  href={href}
  class="group relative block overflow-hidden rounded-xl bg-bg-card ring-1 ring-border transition-all duration-500 ease-out hover:-translate-y-1.5 hover:ring-brand-500/60 hover:shadow-[0_12px_40px_-12px_rgba(244,63,94,0.5)]"
>
  <div class="relative aspect-[2/3] w-full overflow-hidden bg-bg-hover">
    <img
      src={cover}
      alt={manga.title}
      loading={priority ? 'eager' : 'lazy'}
      decoding="async"
      class="absolute inset-0 h-full w-full object-cover transition-transform duration-[700ms] ease-out group-hover:scale-[1.08]"
      onerror="this.src='/placeholder-cover.svg'"
    />

    <!-- Vignette -->
    <div
      class="pointer-events-none absolute inset-0 bg-gradient-to-t from-black/95 via-black/40 to-transparent opacity-90 transition-opacity duration-300 group-hover:opacity-100"
    ></div>
    <div
      class="pointer-events-none absolute inset-0 bg-gradient-to-t from-brand-950/0 via-transparent to-transparent opacity-0 transition-opacity duration-500 group-hover:from-brand-950/40 group-hover:opacity-100"
    ></div>

    <!-- Top badges -->
    <div class="absolute top-2 left-2 right-2 flex items-start justify-between gap-1.5">
      {isNsfw && (
        <span class="badge inline-flex items-center gap-1 rounded-md bg-rose-600/90 px-1.5 py-0.5 text-[10px] font-bold uppercase tracking-wide text-white ring-1 ring-rose-400/30 backdrop-blur">
          18+
        </span>
      )}
      <div class="ml-auto">
        {statusInfo.label && (
          <span class:list={['inline-flex items-center gap-1 rounded-md px-1.5 py-0.5 text-[10px] font-semibold ring-1 ring-inset backdrop-blur', statusInfo.tone]}>
            <span class="inline-block h-1.5 w-1.5 rounded-full bg-current"></span>
            {statusInfo.label}
          </span>
        )}
      </div>
    </div>

    <!-- Hover play indicator -->
    <div class="absolute inset-0 flex items-center justify-center opacity-0 transition-opacity duration-300 group-hover:opacity-100">
      <span class="inline-flex h-12 w-12 items-center justify-center rounded-full bg-brand-600/95 text-white shadow-[0_0_30px_-5px_rgba(244,63,94,0.8)] ring-1 ring-white/20 backdrop-blur transition-transform duration-300 group-hover:scale-110">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
      </span>
    </div>

    <!-- Title at bottom -->
    <div class="absolute inset-x-0 bottom-0 p-3">
      <h3
        class="line-clamp-2 text-sm font-semibold leading-snug text-white drop-shadow-[0_2px_4px_rgba(0,0,0,0.8)]"
        title={manga.title}
      >
        {manga.title}
      </h3>
      <div class="mt-1 flex items-center gap-2 text-[11px] font-medium text-white/70">
        {manga.year && <span>{manga.year}</span>}
        {manga.year && manga.tags && manga.tags.length > 0 && <span class="opacity-50">·</span>}
        {manga.tags && manga.tags.length > 0 && (
          <span class="line-clamp-1">{manga.tags.slice(0, 2).join(' · ')}</span>
        )}
      </div>
    </div>
  </div>
</a>
