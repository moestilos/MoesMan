---
import type { MangaSummary } from '@/lib/providers/types';

interface Props {
  manga: MangaSummary;
  priority?: boolean;
}
const { manga, priority = false } = Astro.props;
const href = `/manga/${manga.id}`;
const cover = manga.coverUrl ?? '/placeholder-cover.svg';
const statusLabel: Record<string, string> = {
  ongoing: 'En curso',
  completed: 'Completo',
  hiatus: 'Pausado',
  cancelled: 'Cancelado',
  unknown: '',
};
---

<a
  href={href}
  class="group relative block overflow-hidden rounded-xl bg-bg-card ring-1 ring-border transition-all duration-300 hover:-translate-y-1 hover:ring-brand-500/50 hover:shadow-card"
>
  <div class="relative aspect-[2/3] w-full overflow-hidden bg-bg-hover">
    <img
      src={cover}
      alt={manga.title}
      loading={priority ? 'eager' : 'lazy'}
      decoding="async"
      class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
      onerror="this.src='/placeholder-cover.svg'"
    />
    <div
      class="pointer-events-none absolute inset-0 bg-gradient-to-t from-black/85 via-black/20 to-transparent opacity-90 transition-opacity"
    >
    </div>
    {manga.status && manga.status !== 'unknown' && (
      <span class="absolute top-2 right-2 badge-brand backdrop-blur">
        {statusLabel[manga.status] ?? manga.status}
      </span>
    )}
    <div class="absolute inset-x-0 bottom-0 p-3">
      <h3
        class="line-clamp-2 text-sm font-semibold leading-snug text-white drop-shadow"
        title={manga.title}
      >
        {manga.title}
      </h3>
      {manga.year && (
        <p class="mt-0.5 text-[11px] font-medium text-white/70">{manga.year}</p>
      )}
    </div>
  </div>
</a>
