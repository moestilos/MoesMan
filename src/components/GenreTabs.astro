---
import { CATEGORIES } from '@/lib/providers/categories';
import { readNsfwCookie } from '@/lib/ssr-prefs';

const nsfw = readNsfwCookie(Astro.request.headers.get('cookie'));
const activeSlug = Astro.url.searchParams.get('genre');
const isSearchRoot = Astro.url.pathname === '/search' && !activeSlug;
const visible = CATEGORIES.filter((c) => nsfw || !c.nsfwOnly);
---

<div class="mb-8">
  <div class="pill-row">
    <a href="/search" class:list={['genre-pill', isSearchRoot ? 'genre-pill--active' : '']}>
      <span class="genre-pill__label">Todo</span>
    </a>
    {visible.map((c) => (
      <a
        href={`/search?genre=${c.slug}`}
        class:list={['genre-pill', activeSlug === c.slug ? 'genre-pill--active' : '']}
      >
        <span class="genre-pill__label">{c.label}</span>
      </a>
    ))}
  </div>
</div>

<style>
  .genre-pill {
    display: inline-flex;
    flex: none;
    align-items: center;
    height: 36px;
    padding: 0 16px;
    border-radius: 9999px;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: -0.005em;
    white-space: nowrap;
    color: rgba(181, 181, 189, 1);
    background:
      linear-gradient(180deg, rgba(255,255,255,0.035) 0%, rgba(255,255,255,0.01) 50%, rgba(0,0,0,0.04) 100%),
      rgba(14, 14, 18, 0.5);
    border: 1px solid rgba(255, 255, 255, 0.06);
    backdrop-filter: blur(10px) saturate(150%);
    -webkit-backdrop-filter: blur(10px) saturate(150%);
    box-shadow: inset 0 1px 0 0 rgba(255, 255, 255, 0.05);
    transition: all 220ms cubic-bezier(0.16, 1, 0.3, 1);
    position: relative;
    isolation: isolate;
  }
  .genre-pill:hover {
    color: #f5f5f7;
    background:
      linear-gradient(180deg, rgba(255,255,255,0.06) 0%, rgba(255,255,255,0.015) 50%, rgba(0,0,0,0.05) 100%),
      rgba(20, 20, 26, 0.6);
    border-color: rgba(255, 255, 255, 0.14);
    transform: translateY(-1px);
    box-shadow:
      inset 0 1px 0 0 rgba(255, 255, 255, 0.08),
      0 4px 14px -6px rgba(0, 0, 0, 0.6);
  }
  .genre-pill:active { transform: translateY(0); }
  .genre-pill__label { position: relative; z-index: 1; }

  .genre-pill--active {
    color: #ffffff;
    background:
      linear-gradient(180deg, rgba(255,255,255,0.08) 0%, rgba(255,255,255,0.02) 50%, rgba(0,0,0,0.06) 100%),
      radial-gradient(120% 180% at 50% -60%, rgb(var(--brand-500) / 0.4) 0%, transparent 60%),
      rgba(20, 20, 26, 0.7);
    border-color: rgb(var(--brand-500) / 0.45);
    box-shadow:
      inset 0 1px 0 0 rgba(255, 255, 255, 0.14),
      inset 0 -1px 0 0 rgba(0, 0, 0, 0.2),
      inset 0 0 0 1px rgb(var(--brand-500) / 0.22),
      0 0 22px -4px rgb(var(--brand-500) / 0.4);
  }
  .genre-pill--active::before {
    content: '';
    position: absolute;
    inset: -1px;
    border-radius: 9999px;
    padding: 1px;
    background: conic-gradient(
      from 0deg at 50% 50%,
      transparent 0deg,
      rgb(var(--brand-400) / 0.55) 40deg,
      transparent 120deg,
      transparent 220deg,
      rgb(var(--brand-500) / 0.45) 280deg,
      transparent 340deg
    );
    -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
    mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
    /* sin rotación */
    z-index: 0;
  }
  .genre-pill--active:hover { transform: translateY(-1px); }
  @keyframes rotate-genre {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }
  @media (prefers-reduced-motion: reduce) {
    .genre-pill--active::before { animation: none; }
  }
</style>
