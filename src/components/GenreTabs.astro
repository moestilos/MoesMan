---
import { CATEGORIES } from '@/lib/providers/categories';
import { readNsfwCookie } from '@/lib/ssr-prefs';

const nsfw = readNsfwCookie(Astro.request.headers.get('cookie'));
const url = Astro.url;
const q = url.searchParams.get('q');

// Multi: ?genres=a,b,c  |  Legacy single: ?genre=a
const rawMulti = url.searchParams.get('genres');
const rawSingle = url.searchParams.get('genre');
const selected = new Set<string>(
  (rawMulti ? rawMulti.split(',') : rawSingle ? [rawSingle] : []).filter(Boolean),
);
const isSearchRoot = url.pathname === '/search' && selected.size === 0 && !q;
const visible = CATEGORIES.filter((c) => nsfw || !c.nsfwOnly);

function buildHref(slug: string): string {
  const next = new Set(selected);
  if (next.has(slug)) next.delete(slug);
  else next.add(slug);
  const params = new URLSearchParams();
  if (q) params.set('q', q);
  if (next.size > 0) params.set('genres', [...next].join(','));
  const qs = params.toString();
  return `/search${qs ? `?${qs}` : ''}`;
}

const selectedCats = visible.filter((c) => selected.has(c.slug));
---

<div class="mb-6 sm:mb-8">
  {selectedCats.length > 0 && (
    <div class="mb-3 flex flex-wrap items-center gap-2">
      <span class="text-[10px] font-bold uppercase tracking-[0.14em] text-fg-subtle">
        Activos
      </span>
      {selectedCats.map((c) => (
        <a
          href={buildHref(c.slug)}
          class="group inline-flex items-center gap-1.5 rounded-full bg-brand-500/15 px-2.5 py-1 text-xs font-semibold text-brand-200 ring-1 ring-inset ring-brand-500/40 transition hover:bg-brand-500/25"
          title={`Quitar ${c.label}`}
        >
          <span>{c.label}</span>
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="opacity-60 transition group-hover:opacity-100">
            <path d="M18 6 6 18M6 6l12 12"/>
          </svg>
        </a>
      ))}
      <a href="/search" class="inline-flex items-center rounded-full px-2.5 py-1 text-xs font-semibold text-fg-subtle hover:text-fg-muted transition">
        Limpiar
      </a>
    </div>
  )}

  <div class="flex flex-wrap gap-2">
    <a
      href="/search"
      class:list={['genre-pill', isSearchRoot ? 'genre-pill--active' : '']}
    >
      <span class="genre-pill__label">Todo</span>
    </a>
    {visible.map((c) => (
      <a
        href={buildHref(c.slug)}
        class:list={['genre-pill', selected.has(c.slug) ? 'genre-pill--active' : '']}
      >
        <span class="genre-pill__label">{c.label}</span>
      </a>
    ))}
  </div>
</div>

<style>
  .genre-pill {
    display: inline-flex;
    flex: none;
    align-items: center;
    height: 34px;
    padding: 0 14px;
    border-radius: 9999px;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: -0.005em;
    white-space: nowrap;
    color: rgba(181, 181, 189, 1);
    background: rgba(255, 255, 255, 0.025);
    border: 1px solid rgba(255, 255, 255, 0.06);
    transition: all 200ms cubic-bezier(0.16, 1, 0.3, 1);
    position: relative;
    isolation: isolate;
  }
  .genre-pill:hover {
    color: #f5f5f7;
    background: rgba(255, 255, 255, 0.055);
    border-color: rgba(255, 255, 255, 0.14);
    transform: translateY(-1px);
  }
  .genre-pill:active { transform: translateY(0); }
  .genre-pill__label { position: relative; z-index: 1; }
  .genre-pill--active {
    color: #ffffff;
    background: rgba(255, 255, 255, 0.09);
    border-color: rgba(255, 255, 255, 0.18);
    box-shadow:
      inset 0 1px 0 0 rgba(255, 255, 255, 0.1),
      0 0 0 1px rgb(var(--brand-500) / 0.4);
  }
  .genre-pill--active:hover {
    background: rgba(255, 255, 255, 0.12);
    transform: translateY(-1px);
  }
</style>
