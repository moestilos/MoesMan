---
import Base from '@/layouts/Base.astro';
import MangaGrid from '@/components/MangaGrid.astro';
import GridSkeleton from '@/components/GridSkeleton.astro';
import { getProvider } from '@/lib/providers';
import { readNsfwCookie } from '@/lib/ssr-prefs';

const nsfw = readNsfwCookie(Astro.request.headers.get('cookie'));

const provider = getProvider('mangadex');

let items: Awaited<ReturnType<typeof provider.browse>> = [];
let error: string | null = null;

if (nsfw) {
  try {
    // Solo contenido explicito (pornographic), ordenado por popularidad
    items = await provider.browse({
      limit: 60,
      contentRating: ['pornographic'],
      order: 'popular',
    });
  } catch (e) {
    error = e instanceof Error ? e.message : 'Error';
  }
}
---

<Base title="Hentai — Ako">
  <section class="mb-8 sm:mb-10">
    <span class="section-kicker">Contenido adulto</span>
    <h1 class="mt-3 font-display text-3xl sm:text-4xl lg:text-5xl font-black leading-[1.05] tracking-tighter">
      <span class="text-gradient-brand">Hentai</span>
    </h1>
    <p class="mt-2 max-w-xl text-[15px] text-fg-muted">
      Contenido explícito 18+. Catálogo uncensored desde MangaDex con rating <code class="text-brand-300">pornographic</code>.
    </p>
  </section>

  {!nsfw ? (
    <section class="mx-auto max-w-md surface p-6 sm:p-8 text-center animate-fade-in-up">
      <span class="mx-auto inline-flex h-14 w-14 items-center justify-center rounded-2xl bg-rose-500/15 text-rose-300 ring-1 ring-rose-500/30">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 9v4M12 17h.01M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0Z"/>
        </svg>
      </span>
      <h2 class="mt-4 font-display text-xl font-bold">Contenido restringido</h2>
      <p class="mt-2 text-sm leading-relaxed text-fg-muted">
        Para acceder debes activar el modo <strong>contenido 18+</strong> en tu menú de usuario y confirmar que eres mayor de edad.
      </p>
      <a href="/" class="btn-primary mt-5 inline-flex">
        Volver al inicio
      </a>
      <p class="mt-4 text-xs text-fg-subtle">
        Activa el toggle "Contenido 18+" desde el ícono ⚙ del header.
      </p>
    </section>
  ) : error ? (
    <div class="rounded-2xl border border-brand-500/30 bg-brand-500/5 p-4 text-sm text-brand-200">
      {error}
    </div>
  ) : items.length === 0 ? (
    <GridSkeleton count={24} />
  ) : (
    <MangaGrid items={items} />
  )}
</Base>
