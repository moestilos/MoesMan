---
import Base from '@/layouts/Base.astro';
import SearchResults from '@/components/SearchResults';
import MangaGrid from '@/components/MangaGrid.astro';
import GridSkeleton from '@/components/GridSkeleton.astro';
import GenreTabs from '@/components/GenreTabs.astro';
import { getProvider } from '@/lib/providers';
import { findCategory } from '@/lib/providers/categories';
import { readNsfwCookie, contentRatingsFor } from '@/lib/ssr-prefs';

const q = (Astro.url.searchParams.get('q') ?? '').trim();
const genreSlug = Astro.url.searchParams.get('genre') ?? '';
const orderParam = Astro.url.searchParams.get('c') ?? '';

const provider = getProvider('mangadex');
const nsfw = readNsfwCookie(Astro.request.headers.get('cookie'));
const ratings = contentRatingsFor(nsfw);

const cat = genreSlug ? findCategory(genreSlug) : null;
const ratingsForCat = cat?.ratingOverride ?? ratings;

let items: Awaited<ReturnType<typeof provider.browse>> = [];
let error: string | null = null;

if (!q) {
  try {
    items = await provider.browse({
      limit: 48,
      tagIds: cat?.tagIds,
      demographic: cat?.demographic,
      originalLanguage: cat?.originalLanguage,
      language: cat?.languageOverride,
      contentRating: ratingsForCat,
      order: orderParam === 'latest' ? 'latest' : 'popular',
    });
  } catch (e) {
    error = e instanceof Error ? e.message : 'Error';
  }
}

const title = q
  ? `Buscar: ${q}`
  : cat
    ? cat.label
    : 'Explorar manga';
---

<Base title={`${title} — Ako`}>
  <section class="mb-8 sm:mb-10">
    <span class="section-kicker">
      {q ? 'Buscador' : cat ? 'Género' : 'Catálogo'}
    </span>
    <h1 class="mt-3 font-display text-3xl sm:text-4xl lg:text-5xl font-black leading-[1.05] tracking-tighter">
      {q ? (
        <>Resultados para <span class="text-gradient-brand">“{q}”</span></>
      ) : cat ? (
        <><span class="text-gradient-brand">{cat.label}</span></>
      ) : (
        <>Explorar <span class="text-gradient-brand">manga</span></>
      )}
    </h1>
    <p class="mt-2 text-[15px] text-fg-muted max-w-xl">
      {q
        ? 'Desliza para cargar más resultados.'
        : cat
          ? `Los más populares del género ${cat.label}.`
          : 'Descubre por géneros o busca por título, autor o etiqueta.'}
    </p>
  </section>

  {!q && <GenreTabs />}

  {error && (
    <div class="mb-6 rounded-xl border border-brand-500/40 bg-brand-500/10 p-4 text-sm text-brand-200">
      {error}
    </div>
  )}

  {q ? (
    <SearchResults client:load query={q} />
  ) : items.length > 0 ? (
    <MangaGrid items={items} />
  ) : !error ? (
    <GridSkeleton count={18} />
  ) : null}
</Base>
