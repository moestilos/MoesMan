    <span class="section-kicker">Tu actividad</span>
    <h1 class="mt-2 font-display text-2xl xs:text-3xl sm:text-4xl font-black tracking-tight">Historial de lectura</h1>
    <p class="mt-1 text-sm text-fg-muted">Continúa donde lo dejaste.</p>
  </header>
  <HistoryView client:only="react" />
</Base>
