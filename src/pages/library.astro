    <span class="section-kicker">Tu colección</span>
    <h1 class="mt-2 font-display text-2xl xs:text-3xl sm:text-4xl font-black tracking-tight">Mi biblioteca</h1>
    <p class="mt-1 text-sm text-fg-muted">Tus mangas guardados.</p>
  </header>
  <LibraryView client:only="react" />
</Base>
