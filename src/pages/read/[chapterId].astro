---
import Base from '@/layouts/Base.astro';
import Reader from '@/components/Reader';
import { getProvider, fetchMergedChapters } from '@/lib/providers';

const { chapterId: rawChapterId } = Astro.params;
if (!rawChapterId) return Astro.redirect('/');
const chapterId = decodeURIComponent(rawChapterId);

const mangaIdParam = Astro.url.searchParams.get('manga');
const providerParam = (Astro.url.searchParams.get('p') ?? 'mangadex').toLowerCase();
const ckHidParam = Astro.url.searchParams.get('ck');
const providerId: 'mangadex' | 'comick' | 'webtoons' =
  providerParam === 'comick' ? 'comick'
  : providerParam === 'webtoons' ? 'webtoons'
  : 'mangadex';
const chapterProvider = getProvider(providerId);
// Para metadatos del manga (titulo/cover) y lista de caps, usar el provider del manga
// (en webtoons el mangaId es del propio provider; en comick/mangadex el manga es de mangadex)
const mangaProviderId = providerId === 'webtoons' ? 'webtoons' : 'mangadex';
const mangaProvider = getProvider(mangaProviderId);

let pages: string[] = [];
let chapters: Array<{ id: string; number: string | null; title: string | null; language: string; providerId: string }> = [];
let error: string | null = null;
const mangaId = mangaIdParam ?? '';
let mangaTitle: string | null = null;
let mangaCoverUrl: string | null = null;

// Timeout helper: evita SSR colgado si MangaDex@Home tarda.
function withTimeout<T>(p: Promise<T>, ms: number, fallback: T): Promise<T> {
  return new Promise<T>((resolve) => {
    const t = setTimeout(() => resolve(fallback), ms);
    p.then((v) => {
      clearTimeout(t);
      resolve(v);
    }).catch(() => {
      clearTimeout(t);
      resolve(fallback);
    });
  });
}

try {
  const pageDataP = withTimeout(
    chapterProvider.getChapterPages(chapterId),
    3_500, // 3.5s máximo bloqueando SSR; el cliente rellena si falla
    { chapterId, providerId: providerId, pages: [] as string[] },
  );
  const mangaDetail = mangaId ? await withTimeout(mangaProvider.getManga(mangaId).catch(() => null), 2_000, null) : null;
  if (mangaDetail) {
    mangaTitle = mangaDetail.title;
    mangaCoverUrl = mangaDetail.coverUrl;
  }
  const chapListP: Promise<Array<{ id: string; providerId: string; number: string | null; title: string | null; language: string }>> =
    mangaId
      ? withTimeout(
          mangaProviderId === 'mangadex'
            ? fetchMergedChapters({
                mdMangaId: mangaId,
                ckHid: ckHidParam,
                title: mangaDetail?.title,
                altTitles: mangaDetail?.altTitles,
              }).then((r) => r.chapters)
            : mangaProvider.listChapters({ mangaId, limit: 500, order: 'asc' }),
          3_000,
          [] as Array<{ id: string; providerId: string; number: string | null; title: string | null; language: string }>,
        )
      : Promise.resolve([]);
  const [pageData, chapList] = await Promise.all([pageDataP, chapListP]);
  pages = pageData.pages;
  chapters = chapList.map((c) => ({
    id: c.id,
    number: c.number,
    title: c.title,
    language: c.language,
    providerId: c.providerId,
  }));
} catch (e) {
  error = e instanceof Error ? e.message : 'Error';
}
---

<Base title="Lector — Ako" fullBleed hideChrome>
  {/* Preload primeras imagenes para inicio instantaneo */}
  <Fragment slot="head">
    {pages.slice(0, 3).map((src) => (
      <link rel="preload" as="image" href={src} fetchpriority="high" />
    ))}
  </Fragment>
  {error ? (
    <div class="container-app py-20 text-center">
      <h1 class="text-2xl font-bold mb-2">Error cargando capítulo</h1>
      <p class="text-fg-muted">{error}</p>
      <a href="/" class="btn-primary mt-6">Volver al inicio</a>
    </div>
  ) : (
    <Reader
      client:load
      mangaId={mangaId}
      mangaTitle={mangaTitle}
      mangaCoverUrl={mangaCoverUrl}
      chapterId={chapterId}
      pages={pages}
      chapters={chapters}
      ckHid={ckHidParam}
    />
  )}
</Base>

<style is:global>
  body.reader-mode {
    background: #000 !important;
    background-image: none !important;
  }
</style>
