---
import Base from '@/layouts/Base.astro';
import AuthForm from '@/components/AuthForm';
---

<Base title="Crear cuenta — MoesMan">
  <div class="mx-auto mt-8 max-w-md">
    <div class="card p-6 sm:p-8 animate-slide-up">
      <h1 class="text-2xl font-bold">Crear cuenta</h1>
      <p class="mt-1 mb-6 text-sm text-fg-muted">Tu biblioteca personal y progreso de lectura sincronizados.</p>
      <AuthForm client:load mode="register" />
    </div>
  </div>
</Base>
