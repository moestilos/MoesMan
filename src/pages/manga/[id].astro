---
import Base from '@/layouts/Base.astro';
import MangaActions from '@/components/MangaActions';
import DownloadChapterButton from '@/components/DownloadChapterButton';
import { getProvider } from '@/lib/providers';

const { id } = Astro.params;
if (!id) return Astro.redirect('/');

const provider = getProvider('mangadex');

let manga: Awaited<ReturnType<typeof provider.getManga>> | null = null;
let chapters: Awaited<ReturnType<typeof provider.listChapters>> = [];
let error: string | null = null;

try {
  [manga, chapters] = await Promise.all([
    provider.getManga(id),
    provider.listChapters({ mangaId: id, limit: 300, order: 'asc' }),
  ]);
} catch (e) {
  error = e instanceof Error ? e.message : 'Error';
}

const cover = manga?.coverUrl ?? '/placeholder-cover.svg';
const statusLabel: Record<string, string> = {
  ongoing: 'En curso',
  completed: 'Completo',
  hiatus: 'Pausado',
  cancelled: 'Cancelado',
  unknown: 'Desconocido',
};
const firstChapter = chapters[0];
---

<Base title={manga ? `${manga.title} — MoesMan` : 'Manga — MoesMan'}>
  {error && (
    <div class="mb-6 rounded-xl border border-brand-500/40 bg-brand-500/10 p-4 text-sm text-brand-200">
      {error}
    </div>
  )}

  {manga && (
    <>
      <section class="relative mb-10 overflow-hidden rounded-3xl ring-1 ring-border">
        {manga.coverUrl && (
          <img
            src={manga.coverUrl}
            alt=""
            aria-hidden="true"
            class="absolute inset-0 h-full w-full scale-110 object-cover blur-3xl opacity-40"
          />
        )}
        <div class="absolute inset-0 bg-gradient-to-t from-bg via-bg/80 to-bg/40"></div>

        <div class="relative z-10 grid gap-6 p-6 sm:p-10 md:grid-cols-[220px_1fr] animate-slide-up">
          <div class="mx-auto w-40 sm:w-48 md:w-full md:max-w-[220px]">
            <img
              src={cover}
              alt={manga.title}
              class="aspect-[2/3] w-full rounded-xl object-cover ring-1 ring-white/10 shadow-card"
            />
          </div>

          <div class="flex min-w-0 flex-col gap-4">
            <div>
              <h1 class="text-2xl sm:text-4xl font-bold leading-tight">{manga.title}</h1>
              {manga.altTitles.length > 0 && (
                <p class="mt-1 line-clamp-1 text-sm text-fg-muted">
                  {manga.altTitles.slice(0, 3).join(' · ')}
                </p>
              )}
            </div>

            <div class="flex flex-wrap items-center gap-2 text-xs">
              {manga.status && <span class="badge-brand">{statusLabel[manga.status]}</span>}
              {manga.year && <span class="badge-muted">{manga.year}</span>}
              {manga.originalLanguage && (
                <span class="badge-muted">Orig: {manga.originalLanguage.toUpperCase()}</span>
              )}
              {manga.availableLanguages?.includes('es') && (
                <span class="badge-brand">ES disponible</span>
              )}
            </div>

            {(manga.authors.length > 0 || manga.artists.length > 0) && (
              <div class="text-sm text-fg-muted space-x-4">
                {manga.authors.length > 0 && (
                  <span><span class="text-fg-subtle">Autor:</span> {manga.authors.join(', ')}</span>
                )}
                {manga.artists.length > 0 && manga.artists.join() !== manga.authors.join() && (
                  <span><span class="text-fg-subtle">Arte:</span> {manga.artists.join(', ')}</span>
                )}
              </div>
            )}

            {manga.tags && manga.tags.length > 0 && (
              <div class="flex flex-wrap gap-1.5">
                {manga.tags.map((t) => <span class="badge-muted">{t}</span>)}
              </div>
            )}

            {manga.description && (
              <p class="max-w-3xl text-sm leading-relaxed text-fg-muted whitespace-pre-line">
                {manga.description}
              </p>
            )}

            <div class="mt-2 flex flex-wrap gap-3">
              {firstChapter && (
                <a
                  href={`/read/${firstChapter.id}?manga=${manga.id}`}
                  class="btn-primary"
                >
                  ▶ Empezar a leer
                </a>
              )}
              <MangaActions
                client:only="react"
                providerId="mangadex"
                mangaId={manga.id}
                title={manga.title}
                coverUrl={manga.coverUrl}
              />
            </div>
          </div>
        </div>
      </section>

      <section>
        <header class="mb-4 flex items-end justify-between">
          <h2 class="text-xl sm:text-2xl font-bold">
            Capítulos <span class="text-fg-muted">· {chapters.length}</span>
          </h2>
          <div class="text-xs text-fg-muted">ES / ES-LA</div>
        </header>

        {chapters.length === 0 ? (
          <p class="py-12 text-center text-fg-muted">
            No hay capítulos traducidos al español disponibles.
          </p>
        ) : (
          <ul class="divide-y divide-border rounded-2xl bg-bg-card ring-1 ring-border overflow-hidden">
            {chapters.map((c) => (
              <li class="flex items-center gap-2 pr-3 transition hover:bg-bg-hover">
                <a
                  href={`/read/${c.id}?manga=${manga.id}`}
                  class="flex min-w-0 flex-1 items-center gap-3 px-4 py-3"
                >
                  <span class="inline-flex h-10 w-14 flex-none items-center justify-center rounded-lg bg-bg ring-1 ring-border text-xs font-semibold text-fg-muted">
                    {c.number ?? '?'}
                  </span>
                  <div class="min-w-0 flex-1">
                    <div class="truncate text-sm font-medium">
                      {c.title || `Capítulo ${c.number ?? ''}`}
                    </div>
                    <div class="mt-0.5 flex items-center gap-2 text-xs text-fg-subtle">
                      <span class="uppercase">{c.language}</span>
                      {c.groupName && <span>· {c.groupName}</span>}
                      {c.publishedAt && (
                        <span>· {new Date(c.publishedAt).toLocaleDateString('es-ES')}</span>
                      )}
                      {c.pages && <span>· {c.pages} pág.</span>}
                    </div>
                  </div>
                  <span class="text-fg-subtle">›</span>
                </a>
                <DownloadChapterButton
                  client:visible
                  chapterId={c.id}
                  chapterNumber={c.number}
                  compact
                />
              </li>
            ))}
          </ul>
        )}
      </section>
    </>
  )}
</Base>
