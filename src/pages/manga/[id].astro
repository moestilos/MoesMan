---
import Base from '@/layouts/Base.astro';
import MangaActions from '@/components/MangaActions';
import DownloadChapterButton from '@/components/DownloadChapterButton';
import DownloadChapterZip from '@/components/DownloadChapterZip';
import DownloadMangaZip from '@/components/DownloadMangaZip';
import TranslatableDesc from '@/components/TranslatableDesc';
import { getProvider } from '@/lib/providers';

const { id } = Astro.params;
if (!id) return Astro.redirect('/');

const provider = getProvider('mangadex');

let manga: Awaited<ReturnType<typeof provider.getManga>> | null = null;
let chapters: Awaited<ReturnType<typeof provider.listChapters>> = [];
let error: string | null = null;

try {
  [manga, chapters] = await Promise.all([
    provider.getManga(id),
    provider.listChapters({ mangaId: id, limit: 300, order: 'asc' }),
  ]);
} catch (e) {
  error = e instanceof Error ? e.message : 'Error';
}

const cover = manga?.coverUrl ?? '/placeholder-cover.svg';
const statusLabel: Record<string, { label: string; tone: string; dot: string }> = {
  ongoing: { label: 'En curso', tone: 'text-emerald-300 ring-emerald-500/25 bg-emerald-500/10', dot: 'bg-emerald-400' },
  completed: { label: 'Completo', tone: 'text-sky-300 ring-sky-500/25 bg-sky-500/10', dot: 'bg-sky-400' },
  hiatus: { label: 'Pausado', tone: 'text-amber-300 ring-amber-500/25 bg-amber-500/10', dot: 'bg-amber-400' },
  cancelled: { label: 'Cancelado', tone: 'text-rose-300 ring-rose-500/25 bg-rose-500/10', dot: 'bg-rose-400' },
  unknown: { label: 'Desconocido', tone: 'text-fg-muted ring-border bg-white/5', dot: 'bg-fg-subtle' },
};
const statusInfo = manga?.status ? statusLabel[manga.status] : statusLabel.unknown;
const firstChapter = chapters[0];
const lastChapter = chapters[chapters.length - 1];
---

<Base title={manga ? `${manga.title} — Ako` : 'Manga — Ako'}>
  {error && (
    <div class="mb-6 rounded-2xl border border-brand-500/30 bg-brand-500/5 p-4 text-sm text-brand-200">
      {error}
    </div>
  )}

  {manga && (
    <article class="animate-fade-in-up">
      <!-- ============ HERO ============ -->
      <section class="relative -mx-4 mb-12 overflow-hidden sm:-mx-6 lg:-mx-10 xl:-mx-14">
        <!-- Blurred background -->
        <div class="absolute inset-0 -z-10">
          {manga.coverUrl && (
            <img
              src={manga.coverUrl}
              alt=""
              aria-hidden="true"
              class="absolute inset-0 h-full w-full scale-125 object-cover blur-3xl opacity-60"
            />
          )}
          <div class="absolute inset-0 bg-gradient-to-b from-bg/60 via-bg/85 to-bg"></div>
          <div class="absolute inset-0 bg-gradient-to-r from-bg/90 via-bg/30 to-transparent"></div>
        </div>

        <div class="container-app relative z-10 py-10 sm:py-16">
          <div class="grid gap-8 md:grid-cols-[260px_1fr] md:gap-10 lg:grid-cols-[300px_1fr] lg:gap-14">
            <!-- Cover -->
            <div class="mx-auto w-44 sm:w-56 md:w-full md:max-w-[300px]">
              <div class="group relative">
                <img
                  src={cover}
                  alt={manga.title}
                  class="aspect-[2/3] w-full rounded-2xl object-cover ring-1 ring-white/10 shadow-card-lg transition-transform duration-500 group-hover:-rotate-1"
                />
                <div class="pointer-events-none absolute inset-0 rounded-2xl shadow-[inset_0_1px_0_0_rgba(255,255,255,0.1)]"></div>
              </div>
            </div>

            <!-- Info -->
            <div class="flex min-w-0 flex-col gap-5">
              <div>
                <span class="section-kicker">Manga · MangaDex</span>
                <h1 class="mt-3 font-display text-3xl sm:text-5xl font-black leading-[1.05] tracking-tighter">{manga.title}</h1>
                {manga.altTitles.length > 0 && (
                  <p class="mt-2 line-clamp-1 text-sm text-fg-muted">
                    Conocido como · {manga.altTitles.slice(0, 3).join(' · ')}
                  </p>
                )}
              </div>

              <!-- Meta chips -->
              <div class="flex flex-wrap items-center gap-2">
                {manga.status && (
                  <span class:list={['inline-flex items-center gap-1.5 rounded-md px-2 py-0.5 text-[11px] font-semibold ring-1 ring-inset', statusInfo.tone]}>
                    <span class:list={['inline-block h-1.5 w-1.5 rounded-full', statusInfo.dot]}></span>
                    {statusInfo.label}
                  </span>
                )}
                {manga.year && (
                  <span class="inline-flex items-center gap-1.5 rounded-md bg-white/[0.04] px-2 py-0.5 text-[11px] font-semibold text-fg-muted ring-1 ring-inset ring-border">
                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                      <line x1="16" y1="2" x2="16" y2="6"/>
                      <line x1="8" y1="2" x2="8" y2="6"/>
                      <line x1="3" y1="10" x2="21" y2="10"/>
                    </svg>
                    {manga.year}
                  </span>
                )}
                {manga.originalLanguage && (
                  <span class="inline-flex items-center gap-1.5 rounded-md bg-white/[0.04] px-2 py-0.5 text-[11px] font-semibold text-fg-muted ring-1 ring-inset ring-border uppercase">
                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <circle cx="12" cy="12" r="10"/>
                      <path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
                    </svg>
                    {manga.originalLanguage}
                  </span>
                )}
                {manga.availableLanguages?.includes('es') && (
                  <span class="inline-flex items-center gap-1.5 rounded-md bg-brand-500/10 px-2 py-0.5 text-[11px] font-semibold text-brand-300 ring-1 ring-inset ring-brand-500/30">
                    ES disponible
                  </span>
                )}
                <span class="inline-flex items-center gap-1.5 rounded-md bg-white/[0.04] px-2 py-0.5 text-[11px] font-semibold text-fg-muted ring-1 ring-inset ring-border">
                  {chapters.length} caps.
                </span>
              </div>

              <!-- Authors -->
              {(manga.authors.length > 0 || manga.artists.length > 0) && (
                <div class="text-sm">
                  {manga.authors.length > 0 && (
                    <p><span class="text-fg-subtle">Autor:</span> <span class="font-medium">{manga.authors.join(', ')}</span></p>
                  )}
                  {manga.artists.length > 0 && manga.artists.join() !== manga.authors.join() && (
                    <p class="mt-0.5"><span class="text-fg-subtle">Arte:</span> <span class="font-medium">{manga.artists.join(', ')}</span></p>
                  )}
                </div>
              )}

              <!-- Tags -->
              {manga.tags && manga.tags.length > 0 && (
                <div class="flex flex-wrap gap-1.5">
                  {manga.tags.map((t) => (
                    <span class="badge-muted">{t}</span>
                  ))}
                </div>
              )}

              <!-- Description con traducción automática -->
              {manga.description && (
                <TranslatableDesc client:load text={manga.description} />
              )}
              <script is:inline>
                (() => {
                  const t = document.getElementById('manga-desc-toggle');
                  const d = document.getElementById('manga-desc');
                  if (!t || !d) return;
                  t.addEventListener('click', () => {
                    const collapsed = d.hasAttribute('data-collapsed');
                    if (collapsed) d.removeAttribute('data-collapsed');
                    else d.setAttribute('data-collapsed', '');
                    t.querySelector('[data-more]').classList.toggle('hidden');
                    t.querySelector('[data-less]').classList.toggle('hidden');
                    t.querySelector('svg').style.transform = collapsed ? 'rotate(180deg)' : 'rotate(0deg)';
                  });
                })();
              </script>

              <!-- CTAs mobile-first: stack full-width en movil, inline en sm+ -->
              <div class="mt-2 grid gap-2 sm:flex sm:flex-wrap sm:items-center sm:gap-3">
                {firstChapter && (
                  <a href={`/read/${firstChapter.id}?manga=${manga.id}`} class="btn-primary w-full sm:w-auto">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
                    Empezar desde Cap. {firstChapter.number ?? '1'}
                  </a>
                )}
                {lastChapter && lastChapter.id !== firstChapter?.id && (
                  <a href={`/read/${lastChapter.id}?manga=${manga.id}`} class="btn-secondary w-full sm:w-auto">
                    Último · Cap. {lastChapter.number ?? '?'}
                  </a>
                )}
                <div class="grid grid-cols-2 gap-2 sm:contents">
                  {chapters.length > 0 && (
                    <DownloadMangaZip
                      client:only="react"
                      mangaTitle={manga.title}
                      chapters={chapters.map((c) => ({ id: c.id, number: c.number, title: c.title }))}
                    />
                  )}
                  <MangaActions
                    client:only="react"
                    providerId="mangadex"
                    mangaId={manga.id}
                    title={manga.title}
                    coverUrl={manga.coverUrl}
                  />
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- ============ CHAPTERS ============ -->
      <section>
        <div class="section-header">
          <div>
            <span class="section-kicker">Contenido</span>
            <h2 class="section-title mt-2">Capítulos <span class="text-fg-muted font-normal">· {chapters.length}</span></h2>
          </div>
          <span class="text-xs font-semibold uppercase tracking-wider text-fg-subtle">ES / ES-LA</span>
        </div>

        {chapters.length === 0 ? (
          <div class="flex flex-col items-center gap-3 py-20 text-center">
            <span class="inline-flex h-14 w-14 items-center justify-center rounded-2xl bg-bg-card ring-1 ring-border text-fg-subtle">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/>
                <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
              </svg>
            </span>
            <p class="text-sm text-fg-muted">No hay capítulos traducidos al español disponibles.</p>
          </div>
        ) : (
          <ul class="divide-y divide-border/50 overflow-hidden rounded-2xl bg-bg-card/40 ring-1 ring-border">
            {chapters.map((c, i) => (
              <li class="group flex items-center gap-1 pr-2 sm:pr-3 transition-colors hover:bg-bg-hover/50">
                <a
                  href={`/read/${c.id}?manga=${manga.id}`}
                  class="flex min-w-0 flex-1 items-center gap-3 px-3 py-3 sm:gap-4 sm:px-4 sm:py-3.5"
                >
                  <span class="flex-none flex items-baseline gap-1 w-12 sm:w-14">
                    <span class="text-[10px] font-bold uppercase tracking-[0.12em] text-fg-subtle">Cap</span>
                    <span class="font-display text-base font-bold tabular-nums text-fg transition group-hover:text-brand-300 sm:text-lg">
                      {c.number ?? '?'}
                    </span>
                  </span>
                  <div class="min-w-0 flex-1">
                    <div class="truncate text-sm font-semibold">
                      {c.title || `Capítulo ${c.number ?? ''}`}
                    </div>
                    <div class="mt-0.5 flex flex-wrap items-center gap-x-2 text-xs text-fg-subtle">
                      <span class="uppercase tracking-wider font-semibold">{c.language}</span>
                      {c.groupName && <><span class="opacity-40 hidden sm:inline">·</span><span class="hidden sm:inline truncate max-w-[160px]">{c.groupName}</span></>}
                      {c.publishedAt && <><span class="opacity-40">·</span><span>{new Date(c.publishedAt).toLocaleDateString('es-ES')}</span></>}
                      {c.pages && <><span class="opacity-40">·</span><span>{c.pages}p</span></>}
                    </div>
                  </div>
                  <span class="hidden sm:inline text-fg-subtle transition-transform group-hover:translate-x-0.5">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                  </span>
                </a>
                <DownloadChapterZip
                  client:visible
                  mangaTitle={manga.title}
                  chapterId={c.id}
                  chapterNumber={c.number}
                  chapterTitle={c.title}
                  compact
                />
              </li>
            ))}
          </ul>
        )}
      </section>
    </article>
  )}
</Base>
