---
import Base from '@/layouts/Base.astro';
import AdminDashboard from '@/components/AdminDashboard';
---

<Base title="Admin — Ako">
  <header class="mb-6 sm:mb-8">
    <div class="flex items-center gap-2.5">
      <span class="inline-flex h-7 w-7 items-center justify-center rounded-lg bg-brand-500/10 text-brand-300 ring-1 ring-inset ring-brand-500/30">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 2 4 6v6c0 5 3.4 9.5 8 10 4.6-.5 8-5 8-10V6l-8-4z"/>
        </svg>
      </span>
      <span class="section-kicker !mt-0">Panel Admin</span>
    </div>
    <h1 class="mt-3 font-display text-2xl xs:text-3xl sm:text-4xl lg:text-5xl font-black tracking-tighter break-words">
      Vista <span class="text-gradient-brand">general</span>
    </h1>
    <p class="mt-2 text-sm text-fg-muted">Métricas, usuarios, catálogo. Visitas dedupeadas por IP y día.</p>
  </header>
  <AdminDashboard client:only="react" />
</Base>
