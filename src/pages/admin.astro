---
import Base from '@/layouts/Base.astro';
import AdminDashboard from '@/components/AdminDashboard';
---

<Base title="Admin — Ako">
  <header class="mb-8">
    <span class="section-kicker">Superuser</span>
    <h1 class="mt-3 font-display text-3xl sm:text-4xl lg:text-5xl font-black tracking-tighter">
      Panel de <span class="text-gradient-brand">administración</span>
    </h1>
    <p class="mt-2 text-sm text-fg-muted">Estadísticas, usuarios, visitas dedupeadas por IP.</p>
  </header>
  <AdminDashboard client:only="react" />
</Base>
