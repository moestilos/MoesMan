---
import Base from '@/layouts/Base.astro';
import MangaGrid from '@/components/MangaGrid.astro';
import MangaCard from '@/components/MangaCard.astro';
import GridSkeleton from '@/components/GridSkeleton.astro';
import ContinueReading from '@/components/ContinueReading';
import GenreTabs from '@/components/GenreTabs.astro';
import HeroCarousel from '@/components/HeroCarousel';
import { getProvider } from '@/lib/providers';
import { readNsfwCookie, contentRatingsFor } from '@/lib/ssr-prefs';
import { CATEGORIES } from '@/lib/providers/categories';

const provider = getProvider('mangadex');
const webtoons = getProvider('webtoons');
const nsfw = readNsfwCookie(Astro.request.headers.get('cookie'));
const ratings = contentRatingsFor(nsfw);

let webtoonsRow: Awaited<ReturnType<typeof webtoons.popular>> = [];
try {
  webtoonsRow = await webtoons.popular({ limit: 12 });
} catch {
  webtoonsRow = [];
}

const featured = nsfw
  ? ['manhwa', 'shonen', 'isekai', 'romance', 'hentai']
  : ['manhwa', 'shonen', 'isekai', 'romance'];

let popular: Awaited<ReturnType<typeof provider.popular>> = [];
let latest: Awaited<ReturnType<typeof provider.latest>> = [];
let genreRows: Array<{ slug: string; label: string; items: typeof popular }> = [];
let error: string | null = null;

try {
  const [pop, lat, ...rows] = await Promise.all([
    provider.popular({ limit: 24, contentRating: ratings }),
    provider.latest({ limit: 18, contentRating: ratings }),
    ...featured.map(async (slug) => {
      const cat = CATEGORIES.find((c) => c.slug === slug);
      if (!cat) return { slug, label: slug, items: [] };
      const items = await provider.browse({
        limit: 12,
        tagIds: cat.tagIds,
        demographic: cat.demographic,
        originalLanguage: cat.originalLanguage,
        language: cat.languageOverride,
        contentRating: cat.ratingOverride ?? ratings,
        order: 'popular',
      });
      return { slug, label: cat.label, items };
    }),
  ]);
  popular = pop;
  latest = lat;
  genreRows = rows;
} catch (e) {
  error = e instanceof Error ? e.message : 'Error cargando';
}

// Fetch detalle de los 5 primeros populares para enriquecer hero (descripcion + lang)
const heroSource = popular.slice(0, 5);
const heroDetails = await Promise.all(
  heroSource.map((m) => provider.getManga(m.id).catch(() => null)),
);
const heroItems = heroSource.map((m, i) => {
  const d = heroDetails[i];
  return {
    id: m.id,
    title: m.title,
    coverUrl: m.coverUrl,
    tags: m.tags ?? [],
    year: m.year ?? null,
    status: m.status,
    originalLanguage: d?.originalLanguage ?? m.originalLanguage,
    description: d?.description
      ? d.description.length > 360 ? d.description.slice(0, 360).replace(/\s\S*$/, '') + '…' : d.description
      : undefined,
  };
});
const topRanked = popular.slice(0, 10);
---

<Base title="Ako — Inicio">
  {error && (
    <div class="mb-6 rounded-2xl border border-brand-500/30 bg-brand-500/5 p-4 text-sm text-brand-200">
      No se pudo conectar con MangaDex: {error}
    </div>
  )}

  {heroItems.length > 0 && <HeroCarousel client:load items={heroItems} />}

  <GenreTabs />

  <ContinueReading client:idle />

  {topRanked.length > 0 && (
    <section class="mb-8 sm:mb-16 animate-fade-in-up">
      <div class="section-header">
        <div>
          <span class="section-kicker">Rankings</span>
          <h2 class="section-title mt-2">Top 10 de la semana</h2>
        </div>
        <a href="/search?c=popular" class="text-xs xs:text-sm font-semibold link-hover text-fg-muted whitespace-nowrap">Ver más →</a>
      </div>
      <div class="rail">
        {topRanked.map((m, i) => (
          <div class="w-[44vw] max-w-[220px] xs:w-[32vw] sm:w-[200px] lg:w-[180px]">
            <MangaCard manga={m} rank={i + 1} priority={i < 5} />
          </div>
        ))}
      </div>
    </section>
  )}

  {popular.length > 10 && (
    <section class="mb-8 sm:mb-16">
      <div class="section-header">
        <div>
          <span class="section-kicker">Tendencia</span>
          <h2 class="section-title mt-2">Populares ahora</h2>
        </div>
      </div>
      <MangaGrid items={popular.slice(10, 22)} />
    </section>
  )}

  {genreRows.map((row) => (
    <section class="mb-8 sm:mb-16">
      <div class="section-header">
        <div>
          <span class="section-kicker">Género</span>
          <h2 class="section-title mt-2">{row.label}</h2>
        </div>
        <a href={`/search?genre=${row.slug}`} class="text-xs xs:text-sm font-semibold link-hover text-fg-muted whitespace-nowrap">Ver más →</a>
      </div>
      {row.items.length === 0 ? (
        <GridSkeleton count={12} />
      ) : (
        <div class="rail">
          {row.items.map((m, i) => (
            <div class="w-[42vw] max-w-[200px] xs:w-[30vw] sm:w-[180px] lg:w-[160px]">
              <MangaCard manga={m} priority={i < 3} />
            </div>
          ))}
        </div>
      )}
    </section>
  ))}

  {webtoonsRow.length > 0 && (
    <section class="mb-8 sm:mb-16">
      <div class="section-header">
        <div>
          <span class="section-kicker">Webtoons · Oficial</span>
          <h2 class="section-title mt-2">Originales de Webtoons</h2>
        </div>
        <a href="/webtoons" class="text-xs xs:text-sm font-semibold link-hover text-fg-muted whitespace-nowrap">Ver más →</a>
      </div>
      <div class="rail">
        {webtoonsRow.map((m, i) => (
          <div class="w-[42vw] max-w-[200px] xs:w-[30vw] sm:w-[180px] lg:w-[160px]">
            <MangaCard manga={m} priority={i < 3} />
          </div>
        ))}
      </div>
    </section>
  )}

  <section class="mb-6">
    <div class="section-header">
      <div>
        <span class="section-kicker">Novedades</span>
        <h2 class="section-title mt-2">Actualizados recientemente</h2>
      </div>
    </div>
    {latest.length === 0 && !error ? <GridSkeleton count={12} /> : <MangaGrid items={latest} />}
  </section>
</Base>
