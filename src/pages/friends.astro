---
import Base from '@/layouts/Base.astro';
import FriendsView from '@/components/FriendsView';
---

<Base title="Amigos — Ako">
  <section class="mb-6 sm:mb-8">
    <span class="section-kicker">Social</span>
    <h1 class="mt-3 font-display text-2xl xs:text-3xl sm:text-4xl lg:text-5xl font-black leading-[1.05] tracking-tighter">
      <span class="text-gradient-brand">Amigos</span>
    </h1>
    <p class="mt-2 text-sm sm:text-[15px] text-fg-muted max-w-xl">
      Ve lo que están leyendo tus amigos y mantente al día de sus capítulos.
    </p>
  </section>

  <FriendsView client:load />
</Base>
